# Copy to .env.local for local dev. Never commit real keys.

# AI provider keys (use one or both based on active endpoint)
ANTHROPIC_API_KEY=your_claude_key_here
GEMINI_API_KEY=your_gemini_key_here

# Needed for server-side Firebase ID token verification in Netlify functions.
# Use the same value as VITE_FIREBASE_API_KEY from your Firebase Web config.
FIREBASE_WEB_API_KEY=your_firebase_web_api_key_here
